{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileSystem": {
    "RootPath": "C:\\Users\\Public\\Documents",
    "MaxUploadSizeBytes": 104857600,
    "AllowedExtensions": []
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 104857600
    }
  }
}
